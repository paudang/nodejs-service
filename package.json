{
  "name": "nodejs-service",
  "version": "1.0.0",
  "description": "Generated by nodejs-quickstart",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "build": "rimraf dist && tsc && tsc-alias && cpx \"src/views/**/*\" dist/views",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "node -e \"try { require('child_process').execSync('husky install'); } catch (e) { console.log('Not a git repository, skipping husky install'); }\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2",
    "ioredis": "^5.3.2",
    "pug": "^3.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/hpp": "^0.2.3",
    "@types/ioredis": "^5.0.0",
    "@types/sequelize": "^4.28.19",
    "@types/morgan": "^1.9.9",
    "rimraf": "^6.0.1",
    "cpx2": "^8.0.0",
    "eslint": "^9.20.1",
    "@eslint/js": "^9.20.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.1",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.4.3",
    "typescript-eslint": "^8.24.1",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/swagger-jsdoc": "^6.0.4",    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.14",
    "supertest": "6.3.3",
    "tsconfig-paths": "^4.2.0",
    "tsc-alias": "^1.8.10",
    "@types/supertest": "^6.0.2"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
