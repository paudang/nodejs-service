# Enforce LF endings for all text files
* text=auto eol=lf

# Explicitly handle common text file types
*.js      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.jsx     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.less    text eol=lf
*.graphql text eol=lf
*.sql     text eol=lf
*.pug     text eol=lf

# Configuration files
.env*          text eol=lf
.editorconfig  text eol=lf
.prettierrc    text eol=lf
.eslintrc*     text eol=lf
.gitignore     text eol=lf
.dockerignore  text eol=lf
.gitattributes text eol=lf

# Assets
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.avif    binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.svg     text eol=lf